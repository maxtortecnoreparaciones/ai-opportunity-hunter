# AI Provider: "openai" para Groq/LM Studio, "gemini" para Google
AI_PROVIDER=openai
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=your-groq-api-key
OPENAI_MODEL=llama-3.3-70b-versatile

# Gemini (solo si AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Scrapers
SCRAPE_LINKEDIN=true
SCRAPE_WELLFOUND=false
SCRAPE_GETONBOARD=true
SCRAPE_WORKANA=true
SCRAPE_COMPUTRABAJO=true
SEARCH_KEYWORDS=desarrollador junior python,automatización python Colombia,analista desarrollador,soporte y desarrollo,técnico sistemas desarrollador,junior developer Bogotá,python developer Colombia

# Scoring
SCORE_THRESHOLD=7.0

# Scheduler
SCHEDULE_INTERVAL_HOURS=6
